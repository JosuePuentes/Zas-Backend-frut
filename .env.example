# MongoDB (usa MongoDB Atlas para producción en Render)
# https://www.mongodb.com/cloud/atlas
MONGODB_URL=mongodb+srv://usuario:password@cluster.mongodb.net/
MONGODB_DB_NAME=zas_batidos

# Server (Render usa $PORT automáticamente)
API_HOST=0.0.0.0
API_PORT=8000

# JWT (cambiar en producción)
JWT_SECRET=tu-clave-secreta-muy-segura-cambiar-en-produccion

# PIN master para crear sucursales (default 1234)
PIN_MASTER=1234
